# 知库 API 环境变量说明
# 复制此文件为 .env，按需填写

# ── 知识库目录 ──────────────────────────────────────
# 数据、索引、备份的存放根目录（Docker 模式默认为 /data）
# ZHIKU_KNOWLEDGE_BASE_DIR=D:\ZhikuLibrary

# ── 语言模型（必填，否则只能检索不能问答）────────────
# 兼容 OpenAI API 的接口地址，例如 Ollama / DeepSeek / 自建
ZHIKU_LLM_API_BASE_URL=http://localhost:11434/v1
ZHIKU_LLM_API_KEY=
ZHIKU_CHAT_MODEL=qwen2.5:7b
# budget / balanced / intensive
ZHIKU_LLM_PARTICIPATION_MODE=balanced

# ── Embedding 模型 ──────────────────────────────────
# 首次建库后不要轻易更改，更改需重建索引
ZHIKU_EMBEDDING_MODEL=bge-m3

# ── B 站 Cookie（可选，提升字幕获取成功率）──────────
ZHIKU_BILIBILI_COOKIE_ENABLED=false
ZHIKU_BILIBILI_COOKIE=
# 或指定 cookie 文件路径
# ZHIKU_BILIBILI_COOKIE_FILE=D:\cookie\bilibili.txt

# ── 转写（ASR）配置（可选）──────────────────────────
# 开启后可对无字幕视频做音频转写
ZHIKU_ASR_ENABLED=false
# ZHIKU_ASR_API_BASE_URL=http://localhost:11434/v1
# ZHIKU_ASR_API_KEY=
# ZHIKU_ASR_MODEL=whisper-1

# ── 服务配置 ────────────────────────────────────────
ZHIKU_PORT=38765
ZHIKU_LLM_TIMEOUT_SECONDS=60
