{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "知库",
  "version": "0.1.0",
  "identifier": "com.zhiku.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "windows": [
      {
        "title": "知库",
        "width": 1280,
        "height": 840,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "useLocalToolsDir": true,
    "resources": {
      "resources/zhiku-service.exe": "zhiku-service.exe"
    }
  }
}
