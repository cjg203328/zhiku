ZHIKU_MODEL_PROVIDER=openai_compatible
ZHIKU_CHAT_MODEL=qwen-plus
ZHIKU_EMBEDDING_MODEL=bge-m3
ZHIKU_LLM_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ZHIKU_LLM_API_KEY=你的国产模型APIKey

# 无字幕视频时的音频转写回退
ZHIKU_ASR_PROVIDER=openai_compatible
ZHIKU_ASR_MODEL=whisper-1
ZHIKU_ASR_API_BASE_URL=https://你的兼容接口/v1
ZHIKU_ASR_API_KEY=你的ASR接口Key

# 如果要改成本地转写，可改成：
# ZHIKU_ASR_PROVIDER=local_whisper
# ZHIKU_ASR_MODEL=small
# 本地模式不需要填写 ASR API Base URL / Key

# 方案1：直接填写你本人登录后的 B站 Cookie
ZHIKU_BILIBILI_COOKIE=

# 方案2：把 Cookie 保存到本地 txt 文件，再填文件路径（二选一即可）
ZHIKU_BILIBILI_COOKIE_FILE=D:\\桌面\\zhiku\\secrets\\bilibili_cookie.txt
